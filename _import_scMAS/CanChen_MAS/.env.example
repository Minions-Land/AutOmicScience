# Repository root. Defaults to this checkout when unset.
CANCHEN_MAS_ROOT=

# Optional raw/query data locations. The repository ships with an empty data/ folder.
CANCHEN_MAS_SEAAD_MERFISH_H5AD=
CANCHEN_MAS_SEAAD_DONOR_H5AD_DIR=
CANCHEN_MAS_KUKANJA_MS_NPZ=
CANCHEN_MAS_KUKANJA_EAE_NPZ=

# Optional foundation-model code/runtime roots.
CANCHEN_MAS_FOUNDATION_MAS_ROOT=
CANCHEN_MAS_SEAAD_MJM_ROOT=

# Foundation-model checkpoint roots. Defaults are under checkpoints/foundation_models/.
CANCHEN_MAS_FOUNDATION_CHECKPOINT_ROOT=
CANCHEN_MAS_GENEFORMER_DIR=
CANCHEN_MAS_SCGPT_DIR=
CANCHEN_MAS_NICHEFORMER_DIR=
CANCHEN_MAS_UCE_4L_DIR=
CANCHEN_MAS_UCE_33L_DIR=
CANCHEN_MAS_UCE_MODEL_PY=

# Optional LLM planner/adjudicator settings for Stage 2, Stage 3, and Stage 4.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
SCMAS_LLM_MODEL=
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=2
OPENAI_TRUST_ENV=true

# Optional OpenAI-compatible embedding/RAG settings used by vendor utilities.
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=
OPENAI_EMBEDDING_MODEL=
OPENAI_EMBEDDING_TIMEOUT=60
RAG_LLM_API_KEY=
RAG_LLM_BASE_URL=
RAG_LLM_MODEL=
BRICK_LLM_API_KEY=
BRICK_LLM_BASE_URL=
BRICK_LLM_MODEL=

# Optional LangSmith tracing. Leave disabled for clean local runs.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=
