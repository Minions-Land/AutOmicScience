{
  "name": "novaeve-agent",
  "version": "0.1.0",
  "description": "Novaeve-Agent — an evolvable, distributed multi-agent framework with a built-in bioinformatics annotation pipeline.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "novaeve": "dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "cli": "tsx src/cli/index.ts cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.73.0",
    "commander": "^12.1.0",
    "nats": "^2.28.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
