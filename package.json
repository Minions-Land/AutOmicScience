{
  "name": "automic-science",
  "version": "0.1.0",
  "description": "AutOmicScience is a bioinformatics multi-agent system for autonomous omics analysis, model selection, and optional foundation-model/reference workflows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aos": "dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc && node scripts/copy-ui-assets.mjs",
    "dev": "node node_modules/tsx/dist/cli.mjs src/cli/index.ts",
    "cli": "node node_modules/tsx/dist/cli.mjs src/cli/index.ts cli",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.73.0",
    "commander": "^12.1.0",
    "nats": "^2.28.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
