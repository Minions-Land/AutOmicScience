# LLM provider API keys
OPENAI_API_KEY=
OPENAI_BASE_URL=
AOS_OPENAI_API_KEY=
AOS_OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Default model, for example:
# gpt-5.5
# gpt-5.4
# gemini-2.5-flash
# anthropic/<provider-model-id>
AOS_MODEL=gpt-5.5

# NATS server, optional, used by chatroom and remote agents.
NATS_URL=nats://localhost:4222

# Bio MAS local runtime, optional.
AOS_PYTHON_BIN=
AOS_RSCRIPT_PATH=
